---
import CardInfo from "@/components/CardInfo.astro";
import curriculum from "@/assets/curriculum.json";
---

<article
  class="relative grid col-span-6 md:col-span-1 grid-cols-2 md:grid-cols-1 gap-5 pf-intro--overview [&>aside>h1]:text-6xl animate-fade-up animate-duration-500 animate-delay-100"
>
  <CardInfo titleHeader="Age" titleI18nKey="hero.age" contentBody={curriculum.age} footerInfo="Years" footerI18nKey="hero.years"/>
  <CardInfo titleHeader="Experience" titleI18nKey="hero.experience" contentBody={curriculum.experienceYears} footerInfo="Years" footerI18nKey="hero.years"/>
</article>
