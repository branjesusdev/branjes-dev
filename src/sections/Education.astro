---
import HeaderTitle from "@/components/HeaderTitle.astro";
import curriculum from "@/assets/curriculum.json";

interface Props {
  class?: string
}

const { class: classList } = Astro.props as Props;
---

<div
  id="education"
  class:list={[classList, "pf-location--overview group relative"]}
>

  <HeaderTitle title="Education"/>

  <section
    class="mt-16 inner-content inner-content--not-padded overflow-hidden p-6 flex flex-col gap-6"
  >
    {
      curriculum.education.map((item) => (
        <div class="flex flex-col gap-1">
          <p class="font-bold text-sky-100 text-sm">{item.degree}</p>
          <p class="text-xs text-cyan-300">{item.institution}</p>
          <p class="text-xs text-sky-100/70">{item.duration}</p>
        </div>
      ))
    }

    {
      curriculum.educationExtras?.length > 0 && (
        <div class="flex flex-wrap gap-2 border-t border-white/10 pt-4">
          {curriculum.educationExtras.map((extra) => (
            <span class="rounded-full border border-lime-300/30 bg-lime-300/10 px-3 py-1 text-xs font-medium text-lime-300">
              {extra}
            </span>
          ))}
        </div>
      )
    }
  </section>
</div>

<script>
  import { initSectionEffects } from "@shared/lib/section-effects";

  initSectionEffects({ selector: "education" });
</script>
