---
import { Image } from "astro:assets";
import curriculum from "@/assets/curriculum.json";
import aiDevIcon from "@/assets/ai-dev.webp";

const firstName = curriculum.fullName.split(" ")[0];

const strings = {
  panelAriaLabel: { en: `Chat about ${firstName}`, es: `Chat sobre ${firstName}` },
  headerTitle: { en: `Ask about ${firstName}`, es: `Pregunta sobre ${firstName}` },
  subtitle: { en: "AI assistant · answers from his CV", es: "Asistente de IA · responde según su CV" },
  closeLabel: { en: "Close chat", es: "Cerrar chat" },
  greeting: {
    en: `Hi! Ask me anything about ${firstName}'s experience, skills, or projects.`,
    es: `¡Hola! Pregúntame lo que quieras sobre la experiencia, habilidades o proyectos de ${firstName}.`,
  },
  placeholder: { en: "Ask a question...", es: "Escribe una pregunta..." },
  sendLabel: { en: "Send", es: "Enviar" },
  openLabel: { en: "Open chat", es: "Abrir chat" },
  iconAlt: { en: "Chat icon", es: "Ícono de chat" },
};
---

<div id="chatbot" class="fixed bottom-6 right-6 z-[1000] flex flex-col items-end gap-3">
  <section
    id="chatbot-panel"
    class="hidden w-[min(22rem,calc(100vw-3rem))] flex-col overflow-hidden rounded-2xl border border-white/10 bg-[#0d1117] shadow-2xl"
    aria-label={strings.panelAriaLabel.en}
    data-i18n-aria-label-en={strings.panelAriaLabel.en}
    data-i18n-aria-label-es={strings.panelAriaLabel.es}
  >
    <header class="flex items-center justify-between gap-2 border-b border-white/10 bg-white/5 px-4 py-3">
      <div class="flex flex-col">
        <p
          class="text-sm font-semibold text-sky-100"
          data-i18n-en={strings.headerTitle.en}
          data-i18n-es={strings.headerTitle.es}
        >
          {strings.headerTitle.en}
        </p>
        <p
          class="text-xs text-sky-100/60"
          data-i18n-en={strings.subtitle.en}
          data-i18n-es={strings.subtitle.es}
        >
          {strings.subtitle.en}
        </p>
      </div>
      <button
        id="chatbot-close"
        type="button"
        aria-label={strings.closeLabel.en}
        data-i18n-aria-label-en={strings.closeLabel.en}
        data-i18n-aria-label-es={strings.closeLabel.es}
        class="rounded-full p-1.5 text-sky-100/70 transition hover:bg-white/10 hover:text-sky-100"
      >
        ✕
      </button>
    </header>

    <div
      id="chatbot-messages"
      data-lenis-prevent
      class="flex max-h-[24rem] min-h-[16rem] flex-col gap-3 overflow-y-auto px-4 py-4"
    >
      <div
        class="max-w-[85%] rounded-2xl rounded-bl-sm bg-white/10 px-3 py-2 text-sm text-sky-100"
        data-i18n-en={strings.greeting.en}
        data-i18n-es={strings.greeting.es}
      >
        {strings.greeting.en}
      </div>
    </div>

    <form id="chatbot-form" class="flex gap-2 border-t border-white/10 p-3">
      <input
        id="chatbot-input"
        type="text"
        autocomplete="off"
        maxlength="800"
        placeholder={strings.placeholder.en}
        data-i18n-placeholder-en={strings.placeholder.en}
        data-i18n-placeholder-es={strings.placeholder.es}
        class="min-w-0 flex-1 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-sky-100 placeholder:text-sky-100/40 focus:border-cyan-300/50 focus:outline-none"
      />
      <button
        type="submit"
        aria-label={strings.sendLabel.en}
        data-i18n-aria-label-en={strings.sendLabel.en}
        data-i18n-aria-label-es={strings.sendLabel.es}
        class="flex size-9 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-cyan-300 to-lime-300 text-[#0d1117] transition hover:brightness-110 disabled:opacity-50"
      >
        ➤
      </button>
    </form>
  </section>

  <button
    id="chatbot-toggle"
    type="button"
    aria-label={strings.openLabel.en}
    data-i18n-aria-label-en={strings.openLabel.en}
    data-i18n-aria-label-es={strings.openLabel.es}
    aria-expanded="false"
    class="flex size-14 items-center justify-center overflow-hidden rounded-full border-2 border-cyan-300/70 bg-[#0d1117] shadow-lg shadow-cyan-300/20 transition hover:scale-105 hover:border-lime-300"
  >
    <Image
      src={aiDevIcon}
      alt={strings.iconAlt.en}
      data-i18n-alt-en={strings.iconAlt.en}
      data-i18n-alt-es={strings.iconAlt.es}
      width={56}
      height={56}
      densities={[1, 2]}
      loading="eager"
      fetchpriority="high"
      class="size-full object-cover"
    />
  </button>
</div>

<script>
  import { getInitialLocale, t, type Locale } from "@shared/lib/i18n";

  interface ChatMessage {
    role: "user" | "assistant";
    content: string;
  }

  let currentLocale: Locale = getInitialLocale();
  window.addEventListener("locale-change", ((event: CustomEvent<Locale>) => {
    currentLocale = event.detail;
  }) as EventListener);

  const root = document.querySelector<HTMLElement>("#chatbot");
  const panel = document.querySelector<HTMLElement>("#chatbot-panel");
  const toggleBtn = document.querySelector<HTMLButtonElement>("#chatbot-toggle");
  const closeBtn = document.querySelector<HTMLButtonElement>("#chatbot-close");
  const form = document.querySelector<HTMLFormElement>("#chatbot-form");
  const input = document.querySelector<HTMLInputElement>("#chatbot-input");
  const messagesEl = document.querySelector<HTMLElement>("#chatbot-messages");

  if (root && panel && toggleBtn && closeBtn && form && input && messagesEl) {
    // Only real exchanged turns go here — the canned greeting bubble is
    // cosmetic and never sent to the API.
    const history: ChatMessage[] = [];
    let isSending = false;

    const ESCAPE_MAP: Record<string, string> = {
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    };
    const escapeHtml = (str: string) => str.replace(/[&<>"']/g, (ch) => ESCAPE_MAP[ch]);

    // The API replies with lightweight Markdown (see chat-prompt.ts's
    // Formatting section) — bullet/numbered lists, **bold**, and
    // [text](url) links. Escape first, then only ever turn escaped text
    // into HTML via these known-safe patterns, so nothing the model
    // outputs can inject arbitrary markup.
    const applyInline = (line: string) =>
      escapeHtml(line)
        .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
        .replace(
          /\[([^\]]+)\]\((https?:\/\/[^\s)]+|mailto:[^\s)]+)\)/g,
          '<a href="$2" target="_blank" rel="noopener noreferrer" class="text-cyan-200 underline decoration-cyan-300/40 underline-offset-2 hover:decoration-cyan-300 break-words">$1</a>',
        );

    const renderMarkdown = (text: string) => {
      const blocks: string[] = [];
      let listBuffer: string[] = [];
      let listType: "ul" | "ol" | null = null;

      const flushList = () => {
        if (!listBuffer.length || !listType) return;
        const items = listBuffer.map((item) => `<li>${applyInline(item)}</li>`).join("");
        const listClass = listType === "ul" ? "list-disc" : "list-decimal";
        blocks.push(`<${listType} class="${listClass} space-y-1 pl-5">${items}</${listType}>`);
        listBuffer = [];
        listType = null;
      };

      for (const rawLine of text.split(/\r?\n/)) {
        const line = rawLine.trim();
        const bulletMatch = line.match(/^[-*]\s+(.*)$/);
        const numberedMatch = line.match(/^\d+[.)]\s+(.*)$/);

        if (bulletMatch) {
          if (listType && listType !== "ul") flushList();
          listType = "ul";
          listBuffer.push(bulletMatch[1]);
          continue;
        }

        if (numberedMatch) {
          if (listType && listType !== "ol") flushList();
          listType = "ol";
          listBuffer.push(numberedMatch[1]);
          continue;
        }

        flushList();
        if (line) blocks.push(`<p class="mb-2 last:mb-0 leading-relaxed">${applyInline(line)}</p>`);
      }

      flushList();
      return blocks.join("");
    };

    const setOpen = (open: boolean) => {
      panel.classList.toggle("hidden", !open);
      panel.classList.toggle("flex", open);
      toggleBtn.setAttribute("aria-expanded", String(open));
      if (open) input.focus();
    };

    toggleBtn.addEventListener("click", () => {
      const isOpen = !panel.classList.contains("hidden");
      setOpen(!isOpen);
    });
    closeBtn.addEventListener("click", () => setOpen(false));

    const appendBubble = (role: ChatMessage["role"], text: string) => {
      const bubble = document.createElement("div");
      bubble.className =
        role === "user"
          ? "max-w-[85%] self-end rounded-2xl rounded-br-sm bg-gradient-to-br from-cyan-300 to-lime-300 px-3 py-2 text-sm text-[#0d1117]"
          : "max-w-[85%] rounded-2xl rounded-bl-sm bg-white/10 px-3 py-2 text-sm text-sky-100";
      if (role === "assistant") {
        bubble.innerHTML = renderMarkdown(text);
      } else {
        bubble.textContent = text;
      }
      messagesEl.append(bubble);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return bubble;
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const text = input.value.trim();
      if (!text || isSending) return;

      isSending = true;
      input.value = "";
      input.disabled = true;

      appendBubble("user", text);
      history.push({ role: "user", content: text });

      const pending = appendBubble("assistant", "…");

      try {
        const response = await fetch("/api/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ messages: history }),
        });

        const data = await response.json();

        if (!response.ok) {
          pending.innerHTML = renderMarkdown(data.error ?? t(currentLocale, "chatbot.genericError"));
        } else {
          pending.innerHTML = renderMarkdown(data.reply);
          history.push({ role: "assistant", content: data.reply });
        }
      } catch {
        pending.innerHTML = renderMarkdown(t(currentLocale, "chatbot.genericError"));
      } finally {
        messagesEl.scrollTop = messagesEl.scrollHeight;
        isSending = false;
        input.disabled = false;
        input.focus();
      }
    });
  }
</script>
